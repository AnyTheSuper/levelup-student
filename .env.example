# Copy to .env.local and fill in from Supabase Dashboard → Project Settings → API

# Required for Supabase (when set, app uses Supabase instead of local SQLite)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: leave Supabase vars empty to use local SQLite in ./data/homework.db
